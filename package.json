{
  "name": "@reacttv/embed-kit",
  "version": "0.1.3",
  "description": "Normalized API across YouTube, Twitch, TikTok, and other embed sources",
  "type": "module",
  "exports": {
    "./base": {
      "types": "./dist/elements/_base/index.d.ts",
      "import": "./dist/elements/_base/index.js",
      "default": "./dist/elements/_base/index.js"
    },
    "./react-embed-kit": {
      "types": "./dist/react-embed-kit/index.d.ts",
      "import": "./dist/react-embed-kit/index.js",
      "default": "./dist/react-embed-kit/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ReactTV/embed-kit.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "globals": {
    "globalThis": "writable"
  },
  "dependencies": {
    "@lit/react": "^1.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json}\"",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "npm run build && concurrently \"npm run build:watch\" \"npx serve . --listen 3333\""
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "embed",
    "youtube",
    "twitch",
    "tiktok",
    "vimeo",
    "iframe",
    "player"
  ],
  "license": "MIT"
}
